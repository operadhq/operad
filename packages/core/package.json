{
  "name": "@operad/core",
  "version": "0.1.0",
  "description": "Event-sourced graph runtime for AI agents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@operad/tsconfig": "workspace:*",
    "typescript": "^5.7.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
