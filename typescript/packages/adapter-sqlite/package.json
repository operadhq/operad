{
  "name": "@operad/adapter-sqlite",
  "version": "0.1.0",
  "description": "SQLite storage adapter for Operad — persistent graph that survives context resets. The live memory for coding agents.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "operad",
    "ai-agents",
    "sqlite",
    "storage-adapter",
    "event-sourcing",
    "persistent-memory"
  ],
  "author": "Operad HQ <hello@operad.dev> (https://operad.dev)",
  "repository": {
    "type": "git",
    "url": "https://github.com/operadhq/operad",
    "directory": "typescript/packages/adapter-sqlite"
  },
  "homepage": "https://operad.dev",
  "bugs": "https://github.com/operadhq/operad/issues",
  "dependencies": {
    "@operad/core": "workspace:*",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@operad/tsconfig": "workspace:*",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
