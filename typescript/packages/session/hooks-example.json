{
  "$schema": "https://docs.anthropic.com/claude-code/hooks-schema.json",
  "_comment": [
    "Example Claude Code hooks configuration for @operad/session.",
    "Copy this into your project's .claude/settings.json under the 'hooks' key.",
    "The hook emits events into ~/.operad/session.db in real-time.",
    "",
    "Environment variables:",
    "  OPERAD_DB_PATH     — Override the database path (default: ~/.operad/session.db)",
    "  OPERAD_GRAPH_ID    — Override the graph ID (default: CLAUDE_SESSION_ID or 'default')"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "command": "echo '{\"hook_type\":\"PreToolUse\",\"tool_name\":\"$TOOL_NAME\",\"tool_input\":$TOOL_INPUT,\"session_id\":\"$CLAUDE_SESSION_ID\"}' | node node_modules/@operad/session/dist/hook.js",
        "description": "Emit tool_called event to Operad graph before tool execution"
      }
    ],
    "PostToolUse": [
      {
        "command": "echo '{\"hook_type\":\"PostToolUse\",\"tool_name\":\"$TOOL_NAME\",\"tool_input\":$TOOL_INPUT,\"session_id\":\"$CLAUDE_SESSION_ID\"}' | node node_modules/@operad/session/dist/hook.js",
        "description": "Emit tool_called event to Operad graph after tool execution"
      }
    ],
    "Notification": [
      {
        "command": "node node_modules/@operad/session/dist/hook.js",
        "description": "Emit goal.set event when user sends a message (payload piped via stdin)"
      }
    ]
  },
  "_usage_notes": {
    "install": "npm install @operad/session",
    "query_from_code": [
      "import { queryFileState } from '@operad/session/query'",
      "",
      "const state = await queryFileState('/path/to/file.ts')",
      "if (state?.hasBeenRead) {",
      "  console.log(`Already read at ${state.lastReadAt}, skipping...`)",
      "}"
    ],
    "query_goals": [
      "import { queryGoals } from '@operad/session/query'",
      "",
      "const goals = await queryGoals()",
      "// [{ goal: 'Fix the login bug', timestamp: '2025-...' }]"
    ]
  }
}
