{
  "name": "@operad/adapter-postgres",
  "version": "0.1.0",
  "description": "Postgres storage adapter for Operad — production-ready with recursive CTE tracing and JSONB queries",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "operad",
    "ai-agents",
    "storage-adapter",
    "postgres",
    "event-sourcing",
    "audit-trail",
    "agent-memory"
  ],
  "author": "Operad HQ <hello@operad.dev> (https://operad.dev)",
  "repository": {
    "type": "git",
    "url": "https://github.com/operadhq/operad",
    "directory": "typescript/packages/adapter-postgres"
  },
  "homepage": "https://operad.dev",
  "bugs": "https://github.com/operadhq/operad/issues",
  "dependencies": {
    "@operad/core": "workspace:*",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@operad/tsconfig": "workspace:*",
    "typescript": "^5.7.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
