{
  "name": "@operad/server",
  "version": "0.1.0",
  "description": "REST API server for Operad — run your event-sourced agent graph over HTTP. Docker-ready.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "operad-server": "./dist/cli.js",
    "operad-worker": "./dist/worker.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "operad",
    "ai-agents",
    "rest-api",
    "event-sourcing",
    "knowledge-graph",
    "docker",
    "hono"
  ],
  "author": "Operad HQ <hello@operad.dev> (https://operad.dev)",
  "repository": {
    "type": "git",
    "url": "https://github.com/operadhq/operad",
    "directory": "typescript/packages/server"
  },
  "homepage": "https://operad.dev",
  "bugs": "https://github.com/operadhq/operad/issues",
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@operad/adapter-memory": "workspace:*",
    "@operad/adapter-postgres": "workspace:*",
    "@operad/core": "workspace:*",
    "hono": "^4.6.0",
    "ioredis": "^5.4.0"
  },
  "devDependencies": {
    "@operad/tsconfig": "workspace:*",
    "@types/node": "^25.9.1",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
