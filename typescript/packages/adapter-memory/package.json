{
  "name": "@operad/adapter-memory",
  "version": "0.1.0",
  "description": "In-memory storage adapter for Operad — perfect for development, testing, and short-lived processes",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "operad",
    "ai-agents",
    "storage-adapter",
    "in-memory",
    "event-sourcing"
  ],
  "author": "Operad HQ <hello@operad.dev> (https://operad.dev)",
  "repository": {
    "type": "git",
    "url": "https://github.com/operadhq/operad",
    "directory": "typescript/packages/adapter-memory"
  },
  "homepage": "https://operad.dev",
  "bugs": "https://github.com/operadhq/operad/issues",
  "dependencies": {
    "@operad/core": "workspace:*"
  },
  "devDependencies": {
    "@operad/tsconfig": "workspace:*",
    "typescript": "^5.7.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
