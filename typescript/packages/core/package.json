{
  "name": "@operad/core",
  "version": "0.1.0",
  "description": "Event-sourced graph runtime for AI agents. Every mutation is an event. Every event has a cause. Every decision is recorded.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai-agents",
    "event-sourcing",
    "knowledge-graph",
    "agent-memory",
    "provenance",
    "audit-trail",
    "causal-chains",
    "decision-records"
  ],
  "author": "Operad HQ <hello@operad.dev> (https://operad.dev)",
  "repository": {
    "type": "git",
    "url": "https://github.com/operadhq/operad",
    "directory": "typescript/packages/core"
  },
  "homepage": "https://operad.dev",
  "bugs": "https://github.com/operadhq/operad/issues",
  "devDependencies": {
    "@operad/tsconfig": "workspace:*",
    "typescript": "^5.7.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
